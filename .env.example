# Copy this file to .env (in this same directory — the SDK repo root)
# and fill in your develop API key. The demos under demo/ all read from
# .env automatically — no need to set the env var or paste it interactively.
#
# Get a `pp_test_*` key from:
#   https://app-develop.poli.page/orgs/{YOUR_ORG}/keys
#
# `.env` is gitignored. This file is here only for the demos; the SDK
# itself doesn't read any environment variables at runtime.

POLI_PAGE_API_KEY=pp_test_replace_me
